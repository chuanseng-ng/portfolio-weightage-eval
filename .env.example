# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-service-role-or-anon-key>

# ── Brokerage ────────────────────────────────────────────────────────────────
BROKERAGE_API_KEY=<your-brokerage-api-key>

# ── Calculation ──────────────────────────────────────────────────────────────
# Currency that all holding values are normalised to before any calculation.
BASE_CURRENCY=SGD

# Fallback overweight threshold (%) for the "any single sector" rule.
# Per-sector overrides (Tech > 35%, Financials > 40%, REITs > 30%) take precedence.
SKEW_THRESHOLD=40

# ── Output ───────────────────────────────────────────────────────────────────
# Directory where JSON snapshot files are written (e.g. output/snapshots).
OUTPUT_DIR=output/snapshots

# Set to true to generate the optional multi-tab Excel report alongside the JSON snapshot.
OUTPUT_EXCEL=false
